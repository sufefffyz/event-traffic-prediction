flowchart LR
    X["History traffic X"] --> STID["Frozen STID base"]
    STID --> YB["Base forecast Y_base"]
    STID --> H["STID hidden state h_i"]

    INC["Observed incident records<br/>history only"] --> META["Type, distance,<br/>relation, age"]
    META --> FEAT["Router feature phi_i,k"]
    X --> PRE["Pre-event state<br/>last, mean, slope"]
    PRE --> FEAT
    H --> FEAT
    K["Horizon embedding k"] --> FEAT

    FEAT --> HEADS["Router heads<br/>impact score, gate,<br/>direction mixture, residuals"]
    META --> MASK["Local geometry mask<br/>M_local"]
    HEADS --> MIX["s_impact * g * r_dir"]
    MASK --> DELTA["Sparse event correction<br/>Delta_event"]
    MIX --> DELTA

    YB --> OUT["Final forecast<br/>Y_hat = Y_base + Delta_event"]
    DELTA --> OUT

    IMPACT_LABEL["Matched-control impact<br/>training label only"] -.-> LOSS["Event-aware losses"]
    OUT --> LOSS
    YB -.-> LOSS
    LOSS -.-> HEADS

    classDef base fill:#e8f1fb,stroke:#2f6fa3,stroke-width:1px,color:#111;
    classDef event fill:#fff2cc,stroke:#a77b00,stroke-width:1px,color:#111;
    classDef loss fill:#f5e8ff,stroke:#7c3aed,stroke-width:1px,color:#111;
    classDef output fill:#e7f4e4,stroke:#3b7d3b,stroke-width:1px,color:#111;
    class X,STID,YB,H,PRE,K base;
    class INC,META,FEAT,HEADS,MASK,MIX,DELTA event;
    class IMPACT_LABEL,LOSS loss;
    class OUT output;
